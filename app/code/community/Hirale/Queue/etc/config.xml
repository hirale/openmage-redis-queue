<?xml version="1.0"?>
<config>
    <modules>
        <Hirale_Queue>
            <version>3.0.0</version>
        </Hirale_Queue>
    </modules>
    <global>
        <models>
            <hirale_queue>
                <class>Hirale_Queue_Model</class>
                <resourceModel>hirale_queue_resource</resourceModel>
            </hirale_queue>
            <hirale_queue_resource>
                <class>Hirale_Queue_Model_Resource</class>
                <entities>
                    <job><table>hirale_queue_job</table></job>
                    <job_event><table>hirale_queue_job_event</table></job_event>
                    <job_archive><table>hirale_queue_job_archive</table></job_archive>
                    <audit><table>hirale_queue_audit</table></audit>
                </entities>
            </hirale_queue_resource>
        </models>
        <resources>
            <hirale_queue_setup>
                <setup>
                    <module>Hirale_Queue</module>
                    <class>Mage_Core_Model_Resource_Setup</class>
                </setup>
                <connection>
                    <use>core_setup</use>
                </connection>
            </hirale_queue_setup>
            <hirale_queue_write>
                <connection>
                    <use>core_write</use>
                </connection>
            </hirale_queue_write>
            <hirale_queue_read>
                <connection>
                    <use>core_read</use>
                </connection>
            </hirale_queue_read>
        </resources>
        <helpers>
            <hirale_queue>
                <class>Hirale_Queue_Helper</class>
            </hirale_queue>
        </helpers>
        <blocks>
            <hirale_queue>
                <class>Hirale_Queue_Block</class>
            </hirale_queue>
        </blocks>
        <events>
            <admin_system_config_changed_section_hirale_queue>
                <observers>
                    <hirale_queue_clear_bus_cache>
                        <type>singleton</type>
                        <class>hirale_queue/observer</class>
                        <method>clearBusCache</method>
                    </hirale_queue_clear_bus_cache>
                </observers>
            </admin_system_config_changed_section_hirale_queue>
            <controller_action_predispatch_adminhtml_system_config_save>
                <observers>
                    <hirale_queue_validate_save>
                        <type>singleton</type>
                        <class>hirale_queue/observer</class>
                        <method>validateConfigOnSave</method>
                    </hirale_queue_validate_save>
                </observers>
            </controller_action_predispatch_adminhtml_system_config_save>
        </events>
        <hirale_queue>
            <!--
                Downstream modules declare their handler + routing mappings by merging
                <hirale_queue><handlers>…</handlers><routing>…</routing></hirale_queue> blocks
                under <global> in their own etc/config.xml. Each child element is named
                after the MessageClass FQCN (using underscore-style class names — XML
                element names cannot contain backslashes). Text content is the value.

                <handlers>
                    <Hirale_AsyncIndex_Message_DrainEventsMessage>hirale_asyncindex/drainEventsHandler</Hirale_AsyncIndex_Message_DrainEventsMessage>
                </handlers>
                <routing>
                    <Hirale_AsyncIndex_Message_FullReindexBatchMessage>full_reindex</Hirale_AsyncIndex_Message_FullReindexBatchMessage>
                </routing>
            -->
            <handlers>
                <!-- Built-in self-test ping for `./maho hirale:queue:test`. -->
                <Hirale_Queue_Message_PingMessage>hirale_queue/pingHandler</Hirale_Queue_Message_PingMessage>
            </handlers>
            <routing/>
        </hirale_queue>
        <crontab>
            <jobs>
                <hirale_queue_archive>
                    <schedule>
                        <cron_expr>17 3 * * *</cron_expr>
                    </schedule>
                    <run>
                        <model>hirale_queue/cron::archiveFinished</model>
                    </run>
                </hirale_queue_archive>
            </jobs>
        </crontab>
    </global>
    <default>
        <hirale_queue>
            <backend>
                <type>redis</type>
                <redis_host>127.0.0.1</redis_host>
                <redis_port>6379</redis_port>
                <redis_database>0</redis_database>
                <redis_use_tls>0</redis_use_tls>
                <redis_tls_verify_peer>1</redis_tls_verify_peer>
                <doctrine_connection>core_write</doctrine_connection>
                <doctrine_table_name>hirale_queue_messages</doctrine_table_name>
                <doctrine_auto_setup>1</doctrine_auto_setup>
            </backend>
            <queues>
                <list>default</list>
            </queues>
            <operational>
                <retry_max_attempts>3</retry_max_attempts>
                <retry_backoff_base_seconds>5</retry_backoff_base_seconds>
                <retry_backoff_cap_seconds>3600</retry_backoff_cap_seconds>
                <payload_max_bytes>262144</payload_max_bytes>
                <redacted_fields>password,token,credit_card,api_key,secret</redacted_fields>
                <audit_admin_actions>1</audit_admin_actions>
            </operational>
            <retention>
                <success_retention_days>7</success_retention_days>
                <failure_retention_days>30</failure_retention_days>
                <archive_retention_days>1</archive_retention_days>
                <archive_batch_size>1000</archive_batch_size>
                <audit_retention_days>90</audit_retention_days>
            </retention>
        </hirale_queue>
    </default>
    <admin>
        <routers>
            <adminhtml>
                <args>
                    <modules>
                        <hirale_queue before="Mage_Adminhtml">Hirale_Queue_Adminhtml</hirale_queue>
                    </modules>
                </args>
            </adminhtml>
        </routers>
    </admin>
</config>
