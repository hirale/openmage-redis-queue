{
    "name": "hirale/openmage-redis-queue",
    "description": "A Redis Streams queue module for OpenMage and Maho",
    "type": "magento-module",
    "license": "OSL-3.0",
    "keywords": [
        "magento",
        "magento1",
        "maho",
        "mahoecommerce",
        "openmage",
        "queue",
        "redis"
    ],
    "require": {
        "magento-hackathon/magento-composer-installer": "^3.0 || ^4.0 || ^99.99",
        "php": ">=8.1 <8.6",
        "monolog/monolog": "^3.9",
        "predis/predis": "^3.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "config": {
        "allow-plugins": {
            "magento-hackathon/magento-composer-installer": false
        }
    },
    "conflict": {
        "mahocommerce/maho": "<25.9",
        "openmage/magento-lts": "<20.17"
    },
    "authors": [
        {
            "name": "Hirale"
        }
    ],
    "extra": {
        "map": [
            [
                "src/app/etc/modules/Hirale_Queue.xml",
                "app/etc/modules/Hirale_Queue.xml"
            ],
            [
                "src/app/code/community/Hirale/Queue",
                "app/code/community/Hirale/Queue"
            ],
            [
                "src/shell/hirale_queue_worker.php",
                "shell/hirale_queue_worker.php"
            ],
            [
                "src/lib/MahoCLI/Commands/HiraleQueueWork.php",
                "lib/MahoCLI/Commands/HiraleQueueWork.php"
            ]
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "HiraleQueue\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    }
}
