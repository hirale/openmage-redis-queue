<?xml version="1.0"?>
<!--
    Maho builds the admin menu and ACL exclusively from merged adminhtml.xml
    files (Mage_Admin_Model_Config) — the <adminhtml> node in config.xml is
    not consulted. Menu and all ACL resources must live here.
-->
<config>
    <menu>
        <system>
            <children>
                <tools>
                    <children>
                        <hirale_queue translate="title" module="hirale_queue">
                            <title>Hirale Queue</title>
                            <action>adminhtml/queue/index</action>
                            <sort_order>120</sort_order>
                        </hirale_queue>
                    </children>
                </tools>
            </children>
        </system>
    </menu>
    <acl>
        <resources>
            <admin>
                <children>
                    <system>
                        <children>
                            <tools>
                                <children>
                                    <hirale_queue translate="title" module="hirale_queue">
                                        <title>Hirale Queue</title>
                                        <sort_order>120</sort_order>
                                    </hirale_queue>
                                </children>
                            </tools>
                            <config>
                                <children>
                                    <hirale_queue translate="title" module="hirale_queue">
                                        <title>Hirale Queue Settings</title>
                                    </hirale_queue>
                                </children>
                            </config>
                        </children>
                    </system>
                </children>
            </admin>
        </resources>
    </acl>
</config>
