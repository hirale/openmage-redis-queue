{
    "name": "hirale/queue",
    "type": "maho-module",
    "license": "OSL-3.0",
    "description": "A queue module for Maho, built on Symfony Messenger. Backend-agnostic (Redis, Doctrine, AMQP, SQS).",
    "keywords": [
        "maho",
        "mahoecommerce",
        "queue",
        "messenger",
        "redis",
        "amqp",
        "doctrine",
        "sqs"
    ],
    "require": {
        "php": ">=8.3",
        "ext-json": "*",
        "ext-redis": "*",
        "mahocommerce/maho": "^26.5",
        "symfony/messenger": "^7.4",
        "symfony/serializer": "^7.4",
        "symfony/redis-messenger": "^7.4",
        "monolog/monolog": "^3.9"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.50"
    },
    "suggest": {
        "symfony/doctrine-messenger": "^7.4 — required for the Doctrine (database) backend",
        "symfony/amqp-messenger": "^7.4 — required for the AMQP/RabbitMQ backend",
        "symfony/amazon-sqs-messenger": "^7.4 — required for the Amazon SQS backend",
        "symfony/beanstalkd-messenger": "^7.4 — required for the Beanstalkd backend"
    },
    "config": {
        "allow-plugins": {
            "mahocommerce/maho-composer-plugin": true
        }
    },
    "autoload": {
        "psr-4": {
            "Hirale\\Queue\\": "lib/Hirale/Queue/",
            "MahoCLI\\Commands\\": "lib/MahoCLI/Commands/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "HiraleQueue\\Tests\\": "tests/"
        }
    },
    "extra": {
        "maho-module-dir": "app/code/community/Hirale/Queue"
    },
    "scripts": {
        "test": "phpunit",
        "phpstan": "phpstan analyse --memory-limit=512M",
        "cs-check": "php-cs-fixer fix --dry-run --diff",
        "cs-fix": "php-cs-fixer fix"
    },
    "authors": [
        {
            "name": "Hirale"
        }
    ]
}
